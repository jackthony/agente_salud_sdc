# OpenAI API Key (requerido si USE_LOCAL=False)
OPENAI_API_KEY=sk-tu-api-key-aqui

# Modo local con Ollama (True = sin costo, requiere Ollama corriendo)
USE_LOCAL=False

# Ollama config (solo si USE_LOCAL=True)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# Modelo OpenAI (FinOps: usar mini por default)
OPENAI_MODEL=gpt-4o-mini
